/*****************************my functions ******************************/
function safehtml($s)
{
    $s=str_replace("&", "&amp;", $s);
    $s=str_replace("<", "&lt;", $s);
    $s=str_replace(">", "&gt;", $s);
    $s=str_replace("'", "&apos;", $s);
    $s=str_replace("\"", "&quot;", $s);
    return $s;
}
function wekapesa($str)
{
    $num= preg_replace('[\D]', '', $str);
    return $num;
}
